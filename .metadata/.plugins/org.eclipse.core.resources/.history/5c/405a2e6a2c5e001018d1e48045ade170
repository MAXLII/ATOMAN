section_perf_base_t section_perf_base_timer = {
    .p_cnt = (uint32_t *)&((*(volatile uint32_t *)(uint32_t)((((((uint32_t)0x40000000U) + 0x00000000U) + 0x00001000U)) + 0x00000024U))),
};
section_perf_t section_timer_cnt_perf = {
    .perf_type = SECTION_PERF_BASE,
    .p_perf = (void *)&section_perf_base_timer,
};
reg_section_t reg_section_perf_base_timer __attribute__((used, __section__("section"))) = {
