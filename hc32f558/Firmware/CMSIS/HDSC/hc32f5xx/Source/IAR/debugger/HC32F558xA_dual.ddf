;; Architecture extensions
#include weak "..\..\..\..\..\ARM\ARMv7-M-ETM.ddf"
#include weak "..\..\..\..\..\ARM\ARMv7-M-TPIU.ddf"
#include weak "..\..\..\..\..\ARM\ARMv7-M-MPU.ddf"

;; Memory information ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;
;; Used to define address zones within the ARM address space (Memory).
;;
;;   Name      may be almost anything
;;   AdrSpace  must be Memory
;;   StartAdr  start of memory block
;;   EndAdr    end of memory block
;;   AccType   type of access, read-only (R), read-write (RW) or SFR (W)

[Memory]
;;         Name             AdrSpace    StartAdr    EndAdr      AccType   Width
Memory =  SystemSFR         Memory      0xE0000000  0xE00FFFFF  W
Memory =  ExtDev            Memory      0x60000000  0x9FFFFFFF  W
Memory =  Periph_BitBand    Memory      0x42000000  0x43FFFFFF  W
Memory =  Periph            Memory      0x40008000  0x400FFFFF  W
Memory =  SRAM_BitBand      Memory      0x22000000  0x23FFFFFF  RW
Memory =  SRAM2             Memory      0x20010000  0x20017FFF  RW
Memory =  SRAM1             Memory      0x20000000  0x2000FFFF  RW
Memory =  SRAMH             Memory      0x1FFF8000  0x1FFFFFFF  RW
Memory =  ICG               Memory      0x0300E000  0x0300FFFF  R
Memory =  SWAP              Memory      0x03002000  0x03002003  R
Memory =  OTP               Memory      0x03000000  0x030017FF  R
Memory =  RemapMem1         Memory      0x02080000  0x020FFFFF  R
Memory =  RemapMem0         Memory      0x02000000  0x0207FFFF  R
Memory =  Flash1            Memory      0x00040000  0x0004FFFF  R
Memory =  Flash0            Memory      0x00000000  0x0000FFFF  R

TrustedRanges = true
UseSfrFilter = true

[SfrInclude]
File = HC32F558.svd
