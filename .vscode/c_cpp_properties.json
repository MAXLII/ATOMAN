{
    "configurations": [
        {
            "name": "gd32",
            "compilerPath": "/usr/bin/arm-none-eabi-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm",
            "compilerArgs": [
                "-mcpu=cortex-m4",
                "-mthumb",
                "-mfpu=fpv4-sp-d16",
                "-mfloat-abi=hard"
            ],
            "includePath": [
                "${workspaceFolder}/code/lib",
                "${workspaceFolder}/code/app",
                "${workspaceFolder}/code/app/demo",
                "${workspaceFolder}/code/comm",
                "${workspaceFolder}/code/ctrl",
                "${workspaceFolder}/code/ctrl/bb",
                "${workspaceFolder}/code/ctrl/pfc",
                "${workspaceFolder}/code/ctrl/inv",
                "${workspaceFolder}/code/interface/ac",
                "${workspaceFolder}/code/interface",
                "${workspaceFolder}/code/interface/common",
                "${workspaceFolder}/code/dbg",
                "${workspaceFolder}/code/section",
                "${workspaceFolder}/gd32g553c/bsp/inc",
                "${workspaceFolder}/gd32g553c/Firmware/CMSIS/GD/GD32G5x3/Include",
                "${workspaceFolder}/gd32g553c/Firmware/CMSIS",
                "${workspaceFolder}/gd32g553c/inc",
                "${workspaceFolder}/gd32g553c/Firmware/GD32G5x3_standard_peripheral/Include"
            ],
            "defines": [
                "GD32G5X3",
                "FIRMWARE_TYPE_ISP",
                "APP_START_ADDR=0x08000000"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/code",
                    "${workspaceFolder}/gd32g553c"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        },
        {
            "name": "plecs_ac",
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64",
            "includePath": [
                "${workspaceFolder}/plecs/common",
                "${workspaceFolder}/plecs/ac",
                "${workspaceFolder}/plecs/ac/app",
                "${workspaceFolder}/plecs/ac/bsp",
                "${workspaceFolder}/code/lib",
                "${workspaceFolder}/code/app",
                "${workspaceFolder}/code/app/ac",
                "${workspaceFolder}/code/comm",
                "${workspaceFolder}/code/ctrl",
                "${workspaceFolder}/code/ctrl/pfc",
                "${workspaceFolder}/code/ctrl/inv",
                "${workspaceFolder}/code/interface/ac",
                "${workspaceFolder}/code/section"
            ],
            "defines": [
                "IS_PLECS",
                "IS_AC"
            ]
        },
        {
            "name": "plecs_dc",
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64",
            "includePath": [
                "${workspaceFolder}/plecs/common",
                "${workspaceFolder}/plecs/dc",
                "${workspaceFolder}/plecs/dc/app",
                "${workspaceFolder}/plecs/dc/bsp",
                "${workspaceFolder}/code/lib",
                "${workspaceFolder}/code/app",
                "${workspaceFolder}/code/app/ac",
                "${workspaceFolder}/code/comm",
                "${workspaceFolder}/code/ctrl",
                "${workspaceFolder}/code/ctrl/pfc",
                "${workspaceFolder}/code/ctrl/inv",
                "${workspaceFolder}/code/interface/ac",
                "${workspaceFolder}/code/section"
            ],
            "defines": [
                "IS_PLECS",
                "IS_DC"
            ]
        }
    ],
    "version": 4
}
